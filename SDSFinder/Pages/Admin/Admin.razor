@page "/Admin"
@inject SDSFinder.Shared.User User
@inject ILogger<Admin> Logger
@using SDSFinder.Components.Admin

<MudTabs>
    @if (isAdminOpen)
    {
        <MudTabPanel Text="Open SDS">
            <OpenSDSAdminPage/>  
        </MudTabPanel>
    }
    @if (isAdminIntercompany)
    {
        <MudTabPanel Text="Intercompany SDS">
            <InterCompanySDSAdminPage/>
        </MudTabPanel>
    }
    @if (isAlerts)
    {
        <MudTabPanel Text="SDS Alerts">
            <AlertsPage />
        </MudTabPanel>
    }
</MudTabs>


@code {
    private bool isAdminOpen = false;
    private bool isAdminIntercompany = false;
    private bool isAlerts = false;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        isAdminOpen =  User.UserTitle.Contains(AppPermissions.ADMIN_OPEN);
        isAdminIntercompany =  User.UserTitle.Contains(AppPermissions.ADMIN_INTERCOMPANY);
        isAlerts = User.UserTitle.Contains(AppPermissions.ADMIN_INTERCOMPANY) || User.UserTitle.Contains(AppPermissions.ADMIN_OPEN);
    }

}
