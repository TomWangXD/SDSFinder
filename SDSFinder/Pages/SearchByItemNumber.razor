@page "/SearchByItemNumber"

@using SDSFinder.Modules.Repositories
@using SDSFinder.Modules.Services
@using SDSFinder.EFModels
@using SDSFinder.EFContexts
@using MudBlazor


@inject IJSRuntime JSRuntime
@inject ILogger<Index> Logger
@inject ISnackbar Snackbar
@inject ISiteService siteService
@inject IItemService itemService
@inject IItemRepository itemRepository
@inject IDocumentService documentService
@inject ILanguageService languageService

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="full-height pa-0">
    <div class="search-section">
        <MudGrid>
            <MudItem xs="4">
                <div class="label-font-size">Item Number</div>
                <MudTextField T="string"
                              @ref="itemRef"
                              @bind-Value="itemNumber"
                              ReadOnly="false"
                              Text="@itemNumber"
                              MaxLength="80"
                              Margin="@Margin.Dense"
                              Dense="true"
                              TextChanged="(async(value) => { itemNumber = value; })"
                              OnBlur="@(async() => await ItemNumberValidation(itemNumber, itemRef, Snackbar))"
                              Variant="Variant.Filled" />
            </MudItem>
            <MudItem xs="4" Class="button">
                <MudButton Variant="Variant.Filled"
                           Size="Size.Medium"
                           Color="Color.Primary"
                           Disabled="@ReadOnly"
                           OnClick="@(async() => await GetTableResultByItem(itemNumber!))">
                    <MudText>Search</MudText>
                </MudButton>
            </MudItem>
        </MudGrid>
    </div>
    <div class="content-section">
        <SDSSearchResultTable TableResults="TableResults"></SDSSearchResultTable>
    </div>
</MudContainer>


@code {
    /// <summary>
    /// This is a function that gets called when the page is first rendered.
    /// This page can be cached and may not always run when changing pages, just the first time within the instance
    /// </summary>

    #region  Properties

    private string? itemNumber { get; set; }
    public bool ReadOnly = false;
    private MudTextField<string> itemRef;
    private List<SDSTableResult?> TableResults = new();
    #endregion

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ReadOnly = true;

        }
        catch (Exception ex)
        {
            Snackbar.Add("An Error Occurred", Severity.Error);
            Logger.LogError(ex.ToString());
            await JSRuntime.InvokeVoidAsync("console.error", ex.ToString());
        }
    }

    private async Task<IEnumerable<CmSiteMaster>> GetSites(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return await siteService.GetAll();
        }
        else
        {
            return await siteService.GetLimitedListBy(x => x.SiteCode.Contains(value) || x.SiteName.Contains(value), 100);
        }

    }

    private async Task ItemNumberValidation(string? itemNumber, MudTextField<string> itemRef, ISnackbar snackbar)
    {
        if (string.IsNullOrEmpty(itemNumber)) return;

        var validationResult = await itemService.ValidateItem(itemNumber);

        if (!validationResult)
        {
            snackbar.Add($"No items found for item number {itemNumber}", Severity.Info);
            ReadOnly = true;
            await itemRef.Clear();
        }
        else
        {
            snackbar.Add("Item found!", Severity.Success);
            ReadOnly = false;
        }
    }

    private async Task GetTableResultByItem(string item)
    {
        TableResults = new();

        if (string.IsNullOrWhiteSpace(item))
        {
            Snackbar.Add("Please enter an item number", Severity.Info);
            return;
        }

        ItemGlbl? fullItem = await itemService.GetBy(x => x.Item == item);
        if (fullItem is null)
        {
            Snackbar.Add("Item could not be found", Severity.Info);
            return;
        }

        List<Document> documents = await GetDocuments(fullItem);
        if (documents.Count == 0)
        {
            Snackbar.Add($"No Safety Documents found with item:{fullItem.Item}", Severity.Info);
            return;
        }

        List<SDSTableResult> tableResults = new();
        foreach (Document document in documents)
        {
            tableResults.Add(BuildTableResult(document, fullItem));
        }

        TableResults = tableResults;
    }

    private async Task<List<Document>> GetDocuments(ItemGlbl item)
    {
        return await documentService.GetListBy(x => x.SafetyDocumentId != null && x.SafetyDocumentId == item.IndSds);
    }

    private SDSTableResult BuildTableResult(Document document, ItemGlbl item)
    {
        string language = languageService.GetLanguage(document.FileName);
        string region = languageService.GetRegion(document.FileName);

        return new SDSTableResult
            {
                ItemNumber = item.Item,
                ItemDescription = item.Description,
                PdfLocation = document?.FileLocation ?? ReportFileLocationNotFound(item),
                Language = language,
                Region = region
            };
    }

    private string ReportFileLocationNotFound(ItemGlbl item)
    {
        Snackbar.Add("Pdf location could not be found. Please contact IT", Severity.Error);
        Logger.LogError($"Item: {item.Item} is missing a pdf location");
        return string.Empty;
    }

    /// <summary>
    /// This is a function that gets called any time that MainLayout.razor re-renders.
    /// </summary>
    protected override void OnParametersSet()
    {
        try
        {
        }
        catch (Exception ex)
        {
            Snackbar.Add("An Error Occurred", Severity.Error);
            Logger.LogError(ex.ToString());
        }
    }


}